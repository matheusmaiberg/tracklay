{% comment %}
  Tracklay Init — Shopify Theme Integration
  ===========================================
  Este snippet configura o Tracklay lendo metafields da loja.

  Recomendado: configure os metafields em:
  Settings > Custom data > Shop metafields

  Namespace: tracklay
  Keys suportadas:
    - gtm_id          (texto curto)
    - measurement_id  (texto curto)
    - worker_url      (texto curto)
    - gtm_server_url  (texto curto)
    - currency        (texto curto)
    - debug           (booleano)

  Ou use um único metafield JSON:
    - config          (JSON)

  Cole este snippet em theme.liquid antes de </head>:
  {% render 'tracklay-init' %}
{% endcomment %}

{% liquid
  assign tracklay_gtm_id = shop.metafields.tracklay.gtm_id | default: ''
  assign tracklay_measurement_id = shop.metafields.tracklay.measurement_id | default: ''
  assign tracklay_worker_url = shop.metafields.tracklay.worker_url | default: ''
  assign tracklay_gtm_server_url = shop.metafields.tracklay.gtm_server_url | default: ''
  assign tracklay_currency = shop.metafields.tracklay.currency | default: cart.currency.iso_code | default: shop.currency
  assign tracklay_debug = shop.metafields.tracklay.debug | default: false

  assign tracklay_config_json = shop.metafields.tracklay.config | default: '{}'
%}

<script>
  (function() {
    'use strict';

    function generateCid() {
      return 'tl_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2, 10);
    }

    function getCookie(name) {
      var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
      return match ? decodeURIComponent(match[2]) : null;
    }

    function setCookie(name, value, days) {
      var expires = new Date();
      expires.setTime(expires.getTime() + days * 24 * 60 * 60 * 1000);
      document.cookie = name + '=' + encodeURIComponent(value) +
        '; expires=' + expires.toUTCString() +
        '; path=/' +
        '; SameSite=Lax' +
        '; Secure';
    }

    var cid = getCookie('_tracklay_cid');
    if (!cid) {
      cid = generateCid();
      setCookie('_tracklay_cid', cid, 730); // 2 anos
    }

    window._tracklay_cid = cid;

    // Metafields individuais
    var metafields = {
      gtmId: {{ tracklay_gtm_id | json }},
      measurementId: {{ tracklay_measurement_id | json }},
      workerBaseUrl: {{ tracklay_worker_url | json }},
      gtmServerUrl: {{ tracklay_gtm_server_url | json }},
      currency: {{ tracklay_currency | json }},
      debug: {{ tracklay_debug | json }}
    };

    // Metafield JSON único (sobrescreve individuais se existir)
    var jsonConfig = {};
    try {
      jsonConfig = {{ tracklay_config_json | json }} || {};
    } catch (e) {
      jsonConfig = {};
    }

    // Merge: metafields individuais <- metafield JSON <- window.TracklayConfig manual
    window.TracklayConfig = Object.assign({}, metafields, jsonConfig, window.TracklayConfig || {});
  })();
</script>

{% comment %}
  Import map para resolver os módulos ES6 do Tracklay contra os asset URLs da Shopify.
  Os arquivos .js devem estar na pasta Assets do tema.
{% endcomment %}
<script type="importmap">
{
  "imports": {
    "./module.config.js": "{{ 'module.config.js' | asset_url }}",
    "./module.logger.js": "{{ 'module.logger.js' | asset_url }}",
    "./module.builder.js": "{{ 'module.builder.js' | asset_url }}",
    "./module.deduplicator.js": "{{ 'module.deduplicator.js' | asset_url }}",
    "./module.cookie-tracker.js": "{{ 'module.cookie-tracker.js' | asset_url }}",
    "./module.loader.js": "{{ 'module.loader.js' | asset_url }}",
    "./module.init.js": "{{ 'module.init.js' | asset_url }}"
  }
}
</script>

<script type="module">
  import { ThemeGTM } from "{{ 'module.init.js' | asset_url }}";
  window.ThemeGTM = ThemeGTM;
</script>
