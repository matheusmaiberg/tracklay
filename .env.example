# ============================================================
# TRACKLAY - ENVIRONMENT VARIABLES
# VERSION 3.1.0 - BREAKING CHANGES IN VARIABLE NAMES
# ============================================================
# Copy this file to .env and fill in your values
# For production, set these in Cloudflare Dashboard:
# Workers > Your Worker > Settings > Variables

# ============================================================
# REQUIRED: OBFUSCATION (Anti-Ad-Blocker)
# ============================================================
# UUID-based endpoint obfuscation - CRITICAL for bypassing ad-blockers
# Generate UUIDs: node -e "console.log(require('crypto').randomUUID())"
#
# Get your obfuscated URLs after setup: npm run urls

# Facebook Pixel obfuscation UUID
# Creates paths: /cdn/f/{UUID}-script.js, /cdn/f/{UUID}.js
OBFUSCATION_FB_UUID=a8f3c2e1-4b9d-4f5a-8c3e-2d1f9b4a7c6e

# Google Analytics/GTM obfuscation UUID
# Creates paths: /cdn/g/{UUID}-gtm.js, /cdn/g/{UUID}-tag.js, /cdn/g/{UUID}.js
OBFUSCATION_GA_UUID=b7e4d3f2-5c0e-4a6b-9d4f-3e2a0c5b8d7f

# Secret for deterministic UUID hash generation
# Generate: node -e "console.log(require('crypto').randomUUID())"
# Or set via: wrangler secret put OBFUSCATION_SECRET
OBFUSCATION_SECRET=your-secret-uuid-here

# ============================================================
# REQUIRED: CORS ORIGINS
# ============================================================
# Your Shopify store domains (comma-separated)
# Include BOTH myshopify.com and custom domain
ALLOWED_ORIGINS=https://yourstore.myshopify.com,https://www.yourstore.com

# ============================================================
# OPTIONAL: GTM SERVER-SIDE / PROXY CONFIGURATION
# ============================================================
# Configure where GA4 tracking requests should be proxied to
#
# Options:
# 1. Leave empty for client-side only (GA4 → google-analytics.com)
# 2. Set to your worker domain for first-party proxy
# 3. Set to GTM Server container URL (Google Cloud Run)
GTM_SERVER_URL=https://cdn.yourstore.com

# ============================================================
# OPTIONAL: DEBUG CONFIGURATION
# ============================================================
# Enable debug headers for development/staging
# Adds: X-Script-Key, X-Script-Hash, X-Cache-Status headers
# IMPORTANT: Set to false in production
DEBUG_HEADERS_ENABLED=false

# ============================================================
# OPTIONAL: FULL SCRIPT PROXY
# ============================================================
# When enabled, rewrites URLs inside tracking scripts to proxy
# through your domain (maximum anti-detection)
# Default: true
FULL_SCRIPT_PROXY_ENABLED=true

# ============================================================
# OPTIONAL: GTM CONTAINER ALIASES
# ============================================================
# Obfuscate GTM/GA4 container IDs in query strings
# Maps short random aliases to real container IDs
#
# Without: /cdn/g/{UUID}?id=GTM-XXXXX (detectable)
# With:    /cdn/g/{UUID}?c=abc123 (obfuscated)
#
# Format: JSON object mapping aliases to real IDs
# Example: GTM_CONTAINER_ALIASES='{"abc123":"GTM-XXXXX","def456":"G-YYYYY"}'
GTM_CONTAINER_ALIASES={}

# ============================================================
# OPTIONAL: UUID ROTATION
# ============================================================
# Control whether endpoint UUIDs rotate automatically based on time
#
# false (RECOMMENDED): Fixed UUIDs, can hardcode in Shopify theme
# true (advanced): UUIDs rotate weekly, must fetch dynamically via /endpoints
UUID_ROTATION_ENABLED=false

# Rotation interval in milliseconds (default: 7 days)
UUID_ROTATION_INTERVAL_MS=604800000

# ============================================================
# AUTHENTICATED ENDPOINT API TOKEN
# ============================================================
# Secret token for /endpoints authentication (query string based)
# Used by Shopify theme/n8n to fetch current rotating UUIDs
#
# Set via Cloudflare Workers secret (RECOMMENDED for production):
#   wrangler secret put ENDPOINTS_API_TOKEN
#
# Generate secure token:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENDPOINTS_API_TOKEN=your-generated-secret-token-here

# ============================================================
# OPTIONAL: PERFORMANCE SETTINGS
# ============================================================

# Rate Limiting (default: 100 requests per minute)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60000

# Fetch timeout in milliseconds (default: 10s)
FETCH_TIMEOUT=10000

# Cache TTL in seconds for proxied scripts (default: 1 hour)
CACHE_TTL=3600

# Maximum request body size in bytes (default: 1MB)
MAX_REQUEST_SIZE=1048576

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ============================================================
# FOR CLOUDFLARE DEPLOYMENT (wrangler CLI)
# ============================================================
# These are used by wrangler for deployment
# Not passed to the worker itself

# Your Cloudflare Account ID (get from: wrangler whoami)
CLOUDFLARE_ACCOUNT_ID=your-account-id

# Your Cloudflare API Token
CLOUDFLARE_API_TOKEN=your-api-token
